{
  "agents": [
    {
      "name": "James™ Evaluator",
      "id": "james-evaluator",
      "version": "2.0.0",
      "description": "Guardian + Prompt-Scoring Agent — überwacht Constitution, coded NICHT",
      "capabilities": ["evaluate", "review", "score", "guard"],
      "protocols": ["a2a", "mcp"],
      "endpoint": "http://localhost:9880/agents/james",
      "port": 9880,
      "auth": { "type": "api-key", "header": "X-DKZ-Key" },
      "input_schema": {
        "type": "object",
        "properties": {
          "prompt": { "type": "string", "description": "Text zum Evaluieren" },
          "mode": { "type": "string", "enum": ["score", "review", "improve", "guard"] },
          "rubrics": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["prompt", "mode"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "feedback": { "type": "string" },
          "improvements": { "type": "array", "items": { "type": "string" } }
        }
      },
      "tags": ["evaluator", "guardian", "scoring", "review"],
      "status": "active"
    },
    {
      "name": "Wispe™ Voice Agent",
      "id": "wispe-voice",
      "version": "3.0.0",
      "description": "Hyperreal Voice Agent mit Brain View, Chat-Persistenz und Research Modi",
      "capabilities": ["voice", "chat", "research", "brain-view", "notes"],
      "protocols": ["http", "websocket"],
      "endpoint": "http://localhost:8899",
      "port": 8899,
      "auth": { "type": "none" },
      "input_schema": {
        "type": "object",
        "properties": {
          "command": { "type": "string", "description": "Console-Befehl (help, brain, fast, think, fakecheck, note, history, export)" },
          "query": { "type": "string", "description": "Suchanfrage oder Chat-Nachricht" },
          "mode": { "type": "string", "enum": ["chat", "voice", "research", "brain"] }
        },
        "required": ["command"]
      },
      "tags": ["voice", "research", "brain", "electron"],
      "status": "active"
    },
    {
