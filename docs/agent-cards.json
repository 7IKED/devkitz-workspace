        "properties": {
          "test_type": { "type": "string", "enum": ["unit", "integration", "e2e", "stress", "audit"] },
          "target": { "type": "string", "description": "URL oder Pfad zum Testen" }
        },
        "required": ["test_type", "target"]
      },
      "tags": ["tester", "testcafe", "bmad", "qa"],
      "status": "active"
    },
    {
      "name": "DkZ Dokumentar™",
      "id": "dkz-dokumentar",
