      "capabilities": ["architecture", "plan", "tech-stack", "tasks"],
      "protocols": ["a2a"],
      "endpoint": "internal://bmad/architekt",
      "auth": { "type": "internal" },
      "input_schema": {
        "type": "object",
        "properties": {
          "task": { "type": "string", "enum": ["plan", "architecture", "tasks", "tech-stack"] },
          "spec": { "type": "string", "description": "Referenz auf spec.md" }
        },
        "required": ["task"]
      },
      "tags": ["architect", "planning", "bmad"],
      "status": "active"
    },
    {
      "name": "DkZ Developer™",
      "id": "dkz-developer",
