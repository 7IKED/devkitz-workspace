      "capabilities": ["document", "readme", "wiki", "changelog"],
      "protocols": ["a2a"],
      "endpoint": "internal://bmad/dokumentar",
      "auth": { "type": "internal" },
      "input_schema": {
        "type": "object",
        "properties": {
          "doc_type": { "type": "string", "enum": ["readme", "changelog", "wiki", "playbook", "walkthrough"] },
          "module": { "type": "string" },
          "changes": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["doc_type"]
      },
      "tags": ["documentation", "bmad", "wiki"],
      "status": "active"
    },
    {
      "name": "NanoBot",
      "id": "nanobot",
      "version": "2.0.0",
      "description": "Auto-Classifier und Agent-Router — leitet Anfragen zum richtigen Agenten",
      "capabilities": ["classify", "route", "registry", "health-check"],
      "protocols": ["internal", "a2a"],
      "endpoint": "http://localhost:9890",
      "port": 9890,
      "auth": { "type": "internal" },
      "input_schema": {
        "type": "object",
        "properties": {
          "input": { "type": "string", "description": "User-Input zum Klassifizieren" },
          "context": { "type": "object", "description": "Optionaler Kontext" },
          "force_agent": { "type": "string", "description": "Agent erzwingen (bypass classifier)" }
        },
        "required": ["input"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "agent": { "type": "string" },
          "confidence": { "type": "number" },
          "response": { "type": "object" }
        }
      },
      "classification_rules": {
        "developer": ["code", "fix", "build", "debug", "implement", "create"],
        "tester": ["test", "check", "verify", "audit", "stress"],
        "james": ["review", "score", "eval", "rate", "improve"],
        "researcher": ["search", "research", "find", "analyze", "compare"],
        "dokumentar": ["doc", "readme", "wiki", "changelog", "write"],
        "pm": ["spec", "story", "requirement", "brief", "plan"],
        "architekt": ["architecture", "design", "structure", "stack"]
      },
      "tags": ["classifier", "router", "orchestration"],
      "status": "active"
    },
    {
      "name": "NanoChat",
      "id": "nanochat",
      "version": "2.0.0",
      "description": "WebSocket Agent-to-Agent Messaging — Echtzeit-Kommunikation zwischen Agenten",
      "capabilities": ["messaging", "broadcast", "subscribe", "history"],
      "protocols": ["websocket", "a2a"],
      "endpoint": "ws://localhost:9891",
      "port": 9891,
      "auth": { "type": "internal" },
      "input_schema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["send", "broadcast", "subscribe", "history"] },
          "from": { "type": "string", "description": "Sender Agent-ID" },
          "to": { "type": "string", "description": "Empfänger Agent-ID (nur bei send)" },
          "channel": { "type": "string", "description": "Channel Name (nur bei subscribe)" },
          "payload": { "type": "object", "description": "Nachricht" }
        },
        "required": ["type", "from"]
      },
      "message_format": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "type": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "channel": { "type": "string" },
          "payload": { "type": "object" },
          "timestamp": { "type": "integer" }
        }
      },
      "channels": ["general", "tasks", "alerts", "reviews", "deployments"],
      "tags": ["messaging", "websocket", "a2a", "realtime"],
      "status": "active"
    },
