      "protocols": ["a2a"],
      "endpoint": "internal://bmad/reviewer",
      "auth": { "type": "internal" },
      "input_schema": {
        "type": "object",
        "properties": {
          "files": { "type": "array", "items": { "type": "string" } },
          "checks": { "type": "array", "items": { "type": "string" }, "default": ["xss", "css-vars", "features-json", "naming"] }
        },
        "required": ["files"]
      },
      "tags": ["reviewer", "quality", "bmad", "coderabbit"],
      "status": "active"
    },
