        },
        "required": ["task_id"]
      },
      "tags": ["developer", "coder", "bmad", "ralph-loop"],
      "status": "active"
    },
    {
      "name": "DkZ Reviewer™",
      "id": "dkz-reviewer",
      "version": "1.0.0",
      "description": "CodeRabbit — esc()? DkZ CSS? features.json? Qualitätsprüfung",
