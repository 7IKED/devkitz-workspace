{
  "name": "dkz-e2e-tests",
  "version": "1.0.0",
  "description": "DkZ™ E2E TestStraße — Playwright-basierte Browser-Tests",
  "type": "module",
  "scripts": {
    "test": "npx playwright test --project=offline",
    "test:headed": "npx playwright test --project=offline --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:stress": "npx playwright test --grep @stress",
    "test:report": "npx playwright show-report",
    "test:server": "npx playwright test --project=server",
    "test:full": "npx playwright test --project=offline --project=server",
    "test:ci": "npx playwright test --project=offline",
    "install-browsers": "npx playwright install chromium",
    "testcafe": "npx testcafe chrome testcafe/",
    "testcafe:headless": "npx testcafe chrome:headless testcafe/",
    "testcafe:kz": "npx testcafe chrome:headless testcafe/kontrollzentrum.testcafe.js",
    "test:kz": "npx playwright test --project=offline specs/kontrollzentrum-smoke.spec.js",
    "test:all": "npx playwright test --project=offline && npx testcafe chrome:headless testcafe/"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "testcafe": "^3.7.4"
  }
}
