{
  "version": "1.0.0",
  "description": "AutoSortierer Regelwerk fuer C:\\DEVKiTZ — 5 Zonen System",
  "deepkeep_path": "C:\\DEVKiTZ\\[DEEPKEEP]",
  "workspace_root": "C:\\DEVKiTZ",
  "sheets_url": "",
  "sheets_fallback_csv": true,
  "csv_log_path": "C:\\DEVKiTZ\\.agents\\scripts\\autosortierer-log.csv",

  "protected": {
    "description": "NIEMALS anfassen — komplett gesperrt",
    "directories": [
      "[DEEPKEEP]",
      "[WORKSPACE]",
      "[HELLO WORLD]",
      "06_NOTEPAD",
      "node_modules"
    ],
    "directory_patterns": [
      "^\\.",
      "^09_BRAIN"
    ],
    "files": [
      "CLAUDE.md",
      "GEMINI.md",
      "REGELWERK.md",
      "README.md",
      "CONTEXT.md",
      "LLM_BOOTSTRAP.md",
      "llms.txt",
      "llms-full.txt",
      ".env",
      ".gitignore",
      ".coderabbit.yaml",
      "package-lock.json"
    ],
    "file_patterns": [
      "^\\..*",
      "^AGENTS\\.md$"
    ]
  },

  "zone_a_inbox": {
    "description": "00_INBOX: Dateien > max_days ungeöffnet → DEEPKEEP + zugehöriger Bereich",
    "folder": "00_INBOX",
    "max_days_unopened": 30,
    "action": "move_to_deepkeep_and_copy_to_bereich"
  },

  "zone_b_bereiche": {
    "description": "01-08: NUR reinsortieren — Dateien die falsch einsortiert sind in richtigen Bereich",
    "folders": [
      "01_PROJECTS",
      "02_RESEARCH",
      "03_MEDIA",
      "04_SYSTEM",
      "05_INTERN",
      "06_RESEARCH",
      "07_PRIVAT",
      "08_PLAYSTATION"
    ],
    "action": "resort_only",
    "never_remove": true,
    "research_never_archive": true,
    "research_folders": ["02_RESEARCH", "06_RESEARCH"],
    "research_old_tag_method": "json_sidecar"
  },

  "zone_c_archive": {
    "description": "99_ARCHIVE: Nur reintun + naming + rausstellen fuer zugehoerigen Bereich",
    "folder": "99_ARCHIVE",
    "action": "archive_naming_and_redistribute",
    "naming_format": "{date}_{bereich}_{name}.{ext}",
    "only_outdated": true
  },

  "zone_d_loose": {
    "description": "Ordner/Dateien OHNE 00-99 Prefix → Original in DEEPKEEP, Kopie in Bereich",
    "action": "move_to_deepkeep_copy_to_bereich",
    "deepkeep_is_original": true,
    "drive_is_original": true
  },

  "extension_to_bereich": {
    ".js":    "01_PROJECTS",
    ".ts":    "01_PROJECTS",
    ".py":    "01_PROJECTS",
    ".html":  "01_PROJECTS",
    ".css":   "01_PROJECTS",
    ".json":  "01_PROJECTS",
    ".jsx":   "01_PROJECTS",
    ".tsx":   "01_PROJECTS",
    ".vue":   "01_PROJECTS",
    ".sh":    "01_PROJECTS",
    ".bat":   "01_PROJECTS",
    ".ps1":   "01_PROJECTS",
    ".yml":   "01_PROJECTS",
    ".yaml":  "01_PROJECTS",

    ".md":    "02_RESEARCH",
    ".pdf":   "02_RESEARCH",
    ".docx":  "02_RESEARCH",
    ".txt":   "02_RESEARCH",
    ".rtf":   "02_RESEARCH",

    ".jpg":   "03_MEDIA",
    ".jpeg":  "03_MEDIA",
    ".png":   "03_MEDIA",
    ".svg":   "03_MEDIA",
    ".webp":  "03_MEDIA",
    ".gif":   "03_MEDIA",
    ".mp4":   "03_MEDIA",
    ".webm":  "03_MEDIA",
