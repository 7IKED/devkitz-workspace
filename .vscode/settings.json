{
  "peacock.color": "#fa1e4e",
  "peacock.affectActivityBar": true,
  "peacock.affectStatusBar": true,
  "peacock.affectTitleBar": true,
  "workbench.colorCustomizations": {
    "activityBar.background": "#fb5075",
    "titleBar.activeBackground": "#fa1e4e",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#fa1e4e99",
    "titleBar.inactiveForeground": "#e7e7e799",
    "statusBar.background": "#fa1e4e",
    "statusBar.foreground": "#e7e7e7",
    "statusBar.noFolderBackground": "#875000",
    "statusBar.noFolderForeground": "#FFFAF2",
    "activityBar.activeBackground": "#fb5075",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#3af906",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#fb5075",
    "statusBarItem.hoverBackground": "#fb5075",
    "statusBarItem.remoteBackground": "#fa1e4e",
    "statusBarItem.remoteForeground": "#e7e7e7"
