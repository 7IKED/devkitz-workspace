    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/CVS": true,
    "**/.ruby-lsp": true,
    "**/.mdocfiles": true,
    ".claude": true,
    ".codex": true,
    ".gemini": true,
    ".venv": true,
    ".superdoc": true
