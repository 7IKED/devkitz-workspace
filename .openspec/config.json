{
  "version": "1.3.1",
  "project": "devkitz-ecosystem",
  "description": "DEVKiTZ KI-Entwickler-Oekosystem mit 152+ Dashboard-Modulen",
  "created": "2026-05-30",
  "specs": [],
  "changes": [],
  "config": {
    "artifact_order": ["proposal", "design", "tasks"],
    "require_grill": true,
    "require_tests": true,
    "auto_archive": false,
    "language": "de",
    "tech_stack": {
      "frontend": "Vanilla HTML5/CSS3/JS ES6+",
      "optional_react": "React+Vite+Tailwind",
      "backend": "Node.js 18+ / Express",
      "data": "localStorage, DuckDB, Apache Iceberg",
      "vps": "KVM8 Ubuntu 22.04, Docker, nginx"
    },
    "rules": {
      "xss_protection": "esc() bei jedem innerHTML",
      "css_variables": "DkZ Design System v2",
      "no_frameworks": "Kein React/Vue/Angular im Dashboard",
      "no_umlauts": "ae, oe, ue, ss ueberall",
      "commit_format": "feat(bereich): beschreibung"
    }
  }
}
