{
  "servers": {
    "devkitz-vps": {
      "command": "python",
      "args": ["-m", "devkitz_mcp.vps_server"],
      "description": "VPS Status, Docker, SSL, nginx",
      "tools": ["get_vps_status", "restart_container", "check_ssl", "list_docker"]
    },
    "devkitz-modules": {
      "command": "python",
      "args": ["-m", "devkitz_mcp.module_server"],
      "description": "Module scannen, validieren, features.json",
      "tools": ["list_modules", "scan_features", "validate_module", "build_module"]
    },
    "devkitz-drive": {
      "command": "python",
      "args": ["-m", "devkitz_mcp.drive_server"],
      "description": "Google Drive Backup, Search, Sync",
      "tools": ["search_drive", "backup_folder", "sync_second_brain"]
    },
    "devkitz-brain": {
      "command": "python",
      "args": ["-m", "devkitz_mcp.brain_server"],
      "description": "Obsidian Second Brain, Daily Notes",
      "tools": ["search_notes", "create_daily", "link_references"]
    },
    "devkitz-github": {
      "command": "python",
      "args": ["-m", "devkitz_mcp.github_server"],
      "description": "Issues, PRs, Projects, Actions",
      "tools": ["create_issue", "list_prs", "sync_kanban", "check_ci"]
    }
  }
}
